# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# PostgreSQL Configuration
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=ticketbot
POSTGRES_USER=ticketbot
POSTGRES_PASSWORD=strong_password_here

# Database URL (constructed automatically, but can override)
DATABASE_URL=postgresql+asyncpg://ticketbot:strong_password_here@db:5432/ticketbot

# Bot Settings
BOT_PREFIX=!
LOG_LEVEL=INFO
MAX_TICKETS_PER_USER=5
TICKET_TRANSCRIPT_CHANNEL=

# Security
SECRET_KEY=generate_a_random_secret_key_here
